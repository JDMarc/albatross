# Controlled Pi shutdown / external power-latch handoff.
# Merge these lines into /boot/firmware/config.txt after verifying that the
# selected GPIOs do not conflict with the installed Pi CAN HAT.
#
# GPIO17: active-low ignition-off or supervisor shutdown request.
# GPIO27: goes high only after Linux has halted; connect to the external
#         latch/supervisor "safe to remove Pi power" input.
dtoverlay=gpio-shutdown,gpio_pin=17,active_low=1,gpio_pull=up,debounce=200
dtoverlay=gpio-poweroff,gpiopin=27,active_low=0,input=0
